{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema Maestro ADN CHAOS v1.5",
  "description": "Gramática universal para configurar cualquier sistema de control CHAOS",
  "type": "object",
  "required": ["schema_version", "especie", "sensores", "actuadores", "reflejos", "ciclos"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$",
      "description": "Versión del schema para compatibilidad"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "autor": {"type": "string"},
        "fecha_creacion": {"type": "string", "format": "date"},
        "version": {"type": "string"},
        "comentarios": {"type": "string"}
      },
      "additionalProperties": false
    },
    "debug": {
      "type": "object",
      "properties": {
        "nivel_log": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "modo_operacion": {
          "type": "string",
          "enum": ["normal", "test", "simulacion"],
          "default": "normal"
        },
        "traza_eventos": {"type": "boolean", "default": false}
      },
      "additionalProperties": false
    },
    "especie": {
      "type": "object",
      "required": ["nombre", "industria", "tipo"],
      "properties": {
        "nombre": {"type": "string"},
        "industria": {"type": "string"},
        "tipo": {"type": "string"},
        "descripcion": {"type": "string"}
      },
      "additionalProperties": false
    },
    "sensores": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["tipo", "unidad", "rango_operativo", "rango_optimo", "umbral_estres", "critico", "peso_atencion"],
          "properties": {
            "tipo": {
              "type": "string",
              "description": "Tipo de sensor (ej: temperatura, humedad, fotoperiodio, presion, flujo, etc.)"
            },
            "unidad": {
              "type": "string",
              "description": "Unidad de medida (celsius, porcentaje, horas)"
            },
            "rango_operativo": {
              "type": "array",
              "items": {"type": "number"},
              "minItems": 2,
              "maxItems": 2,
              "description": "[min, max] rango físico que el sensor puede medir"
            },
            "rango_optimo": {
              "type": "array",
              "items": {"type": "number"},
              "minItems": 2,
              "maxItems": 2,
              "description": "[min, max] rango ideal para el organismo"
            },
            "umbral_estres": {
              "type": "array",
              "items": {"type": "number"},
              "minItems": 2,
              "maxItems": 2,
              "description": "[min, max] umbrales donde comienza el estrés"
            },
            "critico": {
              "type": "boolean",
              "description": "Si true, este sensor es monitoreado por el Ciclo Reptil"
            },
            "peso_atencion": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Peso para cálculo de prioridad de atención"
            },
            "ubicacion": {"type": "string"},
            "descripcion": {"type": "string"}
          },
          "additionalProperties": false
        }
      }
    },
    "actuadores": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["tipo", "estado_inicial", "valores_posibles"],
          "properties": {
            "tipo": {
              "type": "string",
              "description": "Tipo de actuador (ej: ventilador, extractor, luz, valvula, motor, etc.)"
            },
            "estado_inicial": {
              "type": ["string", "number", "boolean", "null"],
              "description": "Valor al iniciar el sistema"
            },
            "valores_posibles": {
              "type": "array",
              "items": {"type": ["string", "number", "boolean"]},
              "description": "Valores que este actuador puede tomar"
            },
            "ubicacion": {"type": "string"},
            "descripcion": {"type": "string"},
            "potencia": {"type": "number"},
            "tiempo_respuesta": {"type": "number"}
          },
          "additionalProperties": false
        }
      }
    },
    "reflejos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nombre", "sensor", "operador", "umbral", "actuador", "accion", "histeresis", "tiempo_bloqueo", "prioridad"],
        "properties": {
          "nombre": {"type": "string"},
          "sensor": {"type": "string"},
          "operador": {
            "type": "string",
            "enum": [">", "<", ">=", "<=", "=="]
          },
          "umbral": {"type": "number"},
          "actuador": {"type": "string"},
          "accion": {
            "type": ["string", "number", "boolean"],
            "description": "Valor a escribir en el actuador"
          },
          "histeresis": {
            "type": "number",
            "minimum": 0,
            "description": "Banda muerta para evitar oscilación"
          },
          "tiempo_bloqueo": {
            "type": "number",
            "minimum": 0,
            "description": "Tiempo mínimo entre activaciones (ms)"
          },
          "prioridad": {
            "type": "integer",
            "minimum": 1,
            "description": "Prioridad para resolver conflictos (menor = más prioritario). En caso de empate, se usa el orden de aparición en el array."
          },
          "descripcion": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "ciclos": {
      "type": "object",
      "required": ["reptil", "cognitivo"],
      "properties": {
        "reptil": {
          "type": "object",
          "required": ["frecuencia_hz"],
          "properties": {
            "frecuencia_hz": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000,
              "description": "Frecuencia del Ciclo Reptil en Hz"
            },
            "prioridad_hilo": {
              "type": "string",
              "enum": ["maxima", "alta", "normal", "baja"],
              "default": "maxima"
            }
          },
          "additionalProperties": false
        },
        "cognitivo": {
          "type": "object",
          "required": ["frecuencia_hz"],
          "properties": {
            "frecuencia_hz": {
              "type": "number",
              "minimum": 0.1,
              "maximum": 60,
              "description": "Frecuencia del Ciclo Cognitivo en Hz"
            },
            "factor_decaimiento_activacion": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "default": 0.7,
              "description": "Inercia emocional del eje de activación"
            },
            "factor_decaimiento_valencia": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "default": 0.7,
              "description": "Inercia emocional del eje de valencia"
            },
            "umbral_activacion_por_error": {
              "type": "number",
              "minimum": 0.1,
              "maximum": 2.0,
              "default": 1.0,
              "description": "Sensibilidad del sistema al error"
            },
            "peso_motivacion": {
              "type": "number",
              "minimum": 0.1,
              "maximum": 2.0,
              "default": 1.0,
              "description": "Peso global para cálculo de motivación"
            },
            "factor_prediccion": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.2,
              "description": "Factor alfa para promedio móvil exponencial (0=solo histórico, 1=solo último valor)"
            },
            "prioridad_hilo": {
              "type": "string",
              "enum": ["maxima", "alta", "normal", "baja"],
              "default": "normal"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "logs": {
      "type": "object",
      "properties": {
        "nivel_detalle": {
          "type": "string",
          "enum": ["minimo", "importante", "completo"],
          "default": "importante",
          "description": "Nivel de detalle para logs orgánicos"
        },
        "formato_timestamp": {
          "type": "string",
          "enum": ["unix", "iso8601"],
          "default": "unix",
          "description": "Formato para timestamps en logs"
        },
        "retencion_dias": {
          "type": "integer",
          "minimum": 1,
          "default": 30,
          "description": "Días a retener logs antiguos"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
